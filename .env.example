# Copy this file to `.env` and replace placeholders with your real DB credentials.
# Prisma will automatically load DATABASE_URL from .env when you run prisma CLI commands.

# PostgreSQL example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Example (replace with your values):
# DATABASE_URL="postgresql://postgres:password@localhost:5432/mobile_shop?schema=public"

# SQLite example:
# DATABASE_URL="file:./dev.db"

# MySQL example:
# DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

# Notes:
# - Do NOT commit your real `.env` to version control. Add `.env` to .gitignore.
# - After creating .env with DATABASE_URL, run:
#     npx prisma generate
#     npx prisma migrate dev --name init
